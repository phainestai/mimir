# Mimir FOB — Environment Variables
# Copy to .env and edit before running locally or with docker compose.
# NEVER commit .env — it is gitignored.
#
# Full reference: docs/architecture/SAO.md § "Environment Variables Reference"

# ── Core / Web service ────────────────────────────────────────────────────────
MIMIR_USER=admin                    # Django superuser username (created on first migrate)
MIMIR_EMAIL=admin@localhost         # Django superuser email
MIMIR_PASSWORD=changeme             # ⚠️  Change this!
DJANGO_DEBUG=True
WEB_PORT=8000                       # Host port for the web UI

# ── MCP facade ────────────────────────────────────────────────────────────────
MCP_PORT=8001                       # Host port for the MCP SSE endpoint
# MIMIR_TOKEN=                      # Optional pre-existing DRF token (auto-fetched if blank)

# ── Galdr AI Engine ───────────────────────────────────────────────────────────
# Required for Galdr PIP review. Without it Galdr is disabled and PIPs are not assessed.
# Default model: claude-sonnet-4-5 (Anthropic). Override with any Anthropic model slug.
ANTHROPIC_API_KEY=sk-ant-...          # required for Galdr to function
GALDR_MODEL=claude-sonnet-4-5

# ── Bug reports (Feedback widget → GitHub Issues) ─────────────────────────────
# REQUIRED in production; optional locally (dry-run mode activates automatically when absent).
#
# GITHUB_TOKEN:   Classic PAT or fine-grained token with Issues: write on GITHUB_BUG_REPO.
#                 Dev: if absent, BUG_REPORT_DRY_RUN is set automatically (form works, no real issue filed).
#                 Prod: must be set as an EB environment property — Feedback widget shows an error without it.
#                 CI/CD: store as GitHub Actions secret GH_BUG_REPORT_TOKEN; deploy-idle.sh propagates it.
#
# GITHUB_BUG_REPO=phainestai/mimir  # default; override for forks
# BUG_REPORT_DRY_RUN=1              # force dry-run even when GITHUB_TOKEN is present
# GITHUB_TOKEN=ghp_...

# ── Email (AWS SES) ───────────────────────────────────────────────────────────
# Dev default: SES enabled (same as prod). Set USE_SES_IN_DEV=0 to print emails to terminal.
# Requires AWS credentials (`aws login` or IAM key pair below).
# DEFAULT_FROM_EMAIL=noreply@featurefactory.io
# AWS_SES_REGION_NAME=us-east-1
# AWS_SES_CONFIGURATION_SET=mimir-transactional
USE_SES_IN_DEV=0                    # 0 = print to terminal (no inbox delivery); 1 = real SES delivery

# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite at mimir.db (dev). Set DATABASE_URL for Postgres.
# DATABASE_URL=postgresql://mimir:password@localhost:5432/mimir

# ── AWS (ECR / SES / EB — CI/CD and prod only) ───────────────────────────────
# AWS_REGION=us-east-1
# AWS_ACCOUNT_ID=411113550285
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxx     # Omit if using IAM instance profile (recommended for EB)
# AWS_SECRET_ACCESS_KEY=...
